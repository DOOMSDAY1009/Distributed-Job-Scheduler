{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "uvicorn backend.main:app --reload",
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
